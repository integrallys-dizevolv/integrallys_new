# ─────────────────────────────────────────────────────────────────────────
# Integrallys — variáveis de ambiente
#
# Copie este arquivo para `.env.local` e preencha os valores.
# ⚠️ NUNCA commite `.env.local` — ele está no .gitignore por conter segredos.
# ─────────────────────────────────────────────────────────────────────────

# URL base da aplicação (usada para montar links absolutos).
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL pública do projeto Supabase — formato: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# 🔴 SENSÍVEL — chave `service_role` do Supabase.
# BYPASSA Row Level Security e dá acesso total ao banco.
# Usada SOMENTE no servidor (ex.: src/lib/auth-payload.ts). Jamais exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# 🔴 SENSÍVEL — segredo para assinar os JWT de sessão (src/lib/auth.ts, via `jose`).
# Gere um valor aleatório forte, ex.: `openssl rand -base64 48`
JWT_SECRET=

# Chave pública (developer key) da API BioDigital Human — visualização 3D de
# anatomia (src/components/shared/anatomy-3d.tsx).
NEXT_PUBLIC_BIODIGITAL_KEY=
