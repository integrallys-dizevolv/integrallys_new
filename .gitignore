# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug / logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NUNCA commitar segredos.
# .env.local contém SUPABASE_SERVICE_ROLE_KEY + JWT_SECRET (vivos).
# Apenas .env.example (sem valores reais) é versionado.
.env*
!.env.example

# MCP local config (contém access tokens — não comitar)
.mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / agent local settings + tooling (específico por usuário/máquina, não product code)
.idea/
/.claude/
# .agents/ = 33 MB de skills vendorizadas — não inflar o repo
/.agents/
.openclaude/

# Dumps e artefatos gerados localmente
repomix-output.xml
*.cookies
gestor-*.json
gestor.cookies
integrallys-refatorad*.xml

# Husky install acidental (pasta criada por flag mal interpretada)
--version/

# Notas de sessão / troubleshooting (não são fonte de verdade do projeto)
RELATORIO_SESSAO_*.md
MIGRATIONS_PENDENTES.md

# Docs internos — não publicar em repo público.
# agents/ = checklists sec-ops + specs de sprint (nomeiam segredos / postura de auth).
# tasks_incremental.md = task tracking interno (inventário de rotas sem escopo per-unit).
/agents/
/tasks_incremental.md
